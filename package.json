    "node": ">=22.6.0"
  },
  "dependencies": {
    "@devvit/web": "0.13.5",
    "devvit": "0.13.5"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "esbuild": "0.28.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
